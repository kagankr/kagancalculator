<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Nefroloji Hesap Makinesi — Spot İdrar Analiz Algoritması</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=JetBrains+Mono:wght@400;500;600&display=swap');

  :root {
    --bg: #0f1117;
    --surface: #1a1d27;
    --surface2: #232735;
    --surface3: #2c3040;
    --border: #363b4e;
    --text: #e8eaf0;
    --text-dim: #9298b0;
    --text-muted: #6b7194;
    --accent: #4fc3f7;
    --accent-dim: rgba(79, 195, 247, 0.12);
    --accent-border: rgba(79, 195, 247, 0.25);
    --green: #66bb6a;
    --green-bg: rgba(102, 187, 106, 0.1);
    --green-border: rgba(102, 187, 106, 0.25);
    --yellow: #ffa726;
    --yellow-bg: rgba(255, 167, 38, 0.1);
    --yellow-border: rgba(255, 167, 38, 0.25);
    --red: #ef5350;
    --red-bg: rgba(239, 83, 80, 0.1);
    --red-border: rgba(239, 83, 80, 0.25);
    --purple: #ab47bc;
    --purple-bg: rgba(171, 71, 188, 0.1);
    --radius: 12px;
    --radius-sm: 8px;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; line-height: 1.6; }
  .app { max-width: 900px; margin: 0 auto; padding: 24px 16px 80px; }

  .header { text-align: center; padding: 32px 0 24px; border-bottom: 1px solid var(--border); margin-bottom: 28px; }
  .header-badge { display: inline-flex; align-items: center; gap: 8px; background: var(--accent-dim); border: 1px solid var(--accent-border); border-radius: 20px; padding: 5px 14px; font-size: 12px; font-weight: 500; color: var(--accent); margin-bottom: 14px; letter-spacing: 0.5px; text-transform: uppercase; }
  .header h1 { font-size: 26px; font-weight: 700; letter-spacing: -0.5px; margin-bottom: 6px; }
  .header .author { color: var(--text-muted); font-size: 13px; margin-top: 4px; font-style: italic; }

  .param-group { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); margin-bottom: 16px; overflow: hidden; }
  .param-group-header { display: flex; align-items: center; justify-content: space-between; padding: 14px 18px; cursor: pointer; user-select: none; transition: background 0.15s; }
  .param-group-header:hover { background: var(--surface2); }
  .param-group-title { display: flex; align-items: center; gap: 10px; font-weight: 600; font-size: 15px; }
  .param-group-icon { width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 16px; }
  .icon-urine { background: rgba(255, 193, 7, 0.15); }
  .icon-serum { background: rgba(239, 83, 80, 0.15); }
  .chevron { transition: transform 0.2s; color: var(--text-muted); font-size: 18px; }
  .chevron.open { transform: rotate(180deg); }

  .param-group-body { padding: 0 18px 18px; display: none; }
  .param-group-body.open { display: block; }
  .param-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 12px; }

  .input-wrap { position: relative; }
  .input-wrap label { display: block; font-size: 12px; font-weight: 500; color: var(--text-dim); margin-bottom: 5px; letter-spacing: 0.3px; }
  .input-wrap label .unit { color: var(--text-muted); font-weight: 400; }
  .input-wrap input {
    width: 100%; padding: 10px 12px; background: var(--surface2); border: 1px solid var(--border); border-radius: var(--radius-sm);
    color: var(--text); font-family: 'JetBrains Mono', monospace; font-size: 14px; font-weight: 500; outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .input-wrap input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-dim); }
  .input-wrap input::placeholder { color: var(--text-muted); font-weight: 400; font-size: 12px; }
  .input-wrap input:disabled {
    background: var(--surface3); color: var(--accent); border: 1px dashed var(--accent-border);
    cursor: default; font-size: 13px; font-weight: 600;
  }

  .osm-formula-hint { font-size: 11px; color: var(--text-muted); font-family: 'JetBrains Mono', monospace; margin-top: 4px; line-height: 1.4; }
  .osm-calc-indicator { display: inline-flex; align-items: center; gap: 4px; font-size: 10px; color: var(--accent); font-weight: 500; margin-top: 2px; }

  .actions { display: flex; gap: 12px; margin-top: 24px; }
  .btn { flex: 1; padding: 13px 20px; border-radius: var(--radius-sm); font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 600; cursor: pointer; border: none; transition: all 0.15s; }
  .btn-primary { background: var(--accent); color: #0f1117; }
  .btn-primary:hover { filter: brightness(1.1); transform: translateY(-1px); }
  .btn-secondary { background: var(--surface2); color: var(--text-dim); border: 1px solid var(--border); }
  .btn-secondary:hover { background: var(--surface3); color: var(--text); }

  .results-container { margin-top: 28px; }
  .results-title { font-size: 18px; font-weight: 700; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }

  .result-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px 18px; margin-bottom: 12px; animation: fadeIn 0.3s ease; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
  .result-card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
  .result-card-name { font-weight: 600; font-size: 15px; }
  .result-card-value { font-family: 'JetBrains Mono', monospace; font-weight: 600; font-size: 15px; }

  .result-badge { display: inline-flex; align-items: center; gap: 5px; padding: 3px 10px; border-radius: 12px; font-size: 12px; font-weight: 600; }
  .badge-normal { background: var(--green-bg); color: var(--green); border: 1px solid var(--green-border); }
  .badge-high { background: var(--red-bg); color: var(--red); border: 1px solid var(--red-border); }
  .badge-low { background: var(--yellow-bg); color: var(--yellow); border: 1px solid var(--yellow-border); }
  .badge-info { background: var(--purple-bg); color: var(--purple); border: 1px solid rgba(171,71,188,0.25); }
  .badge-grey { background: var(--surface2); color: var(--text-dim); border: 1px solid var(--border); }

  .result-detail { font-size: 13px; color: var(--text-dim); line-height: 1.55; margin-top: 6px; }
  .result-formula { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--text-muted); background: var(--surface2); border-radius: 6px; padding: 8px 12px; margin-top: 8px; border: 1px solid var(--border); }

  .suggestion-card { background: var(--accent-dim); border: 1px solid var(--accent-border); border-radius: var(--radius); padding: 16px 18px; margin-bottom: 12px; animation: fadeIn 0.35s ease; }
  .suggestion-card h4 { color: var(--accent); font-size: 14px; font-weight: 600; margin-bottom: 8px; display: flex; align-items: center; gap: 6px; }
  .suggestion-card p { font-size: 13px; color: var(--text-dim); line-height: 1.5; }

  .diff-section { margin-top: 8px; }
  .diff-title { font-size: 12px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; }
  .diff-tags { display: flex; flex-wrap: wrap; gap: 5px; }
  .diff-tag { font-size: 11px; padding: 2px 8px; border-radius: 10px; background: var(--surface2); color: var(--text-dim); border: 1px solid var(--border); }
  .section-divider { height: 1px; background: var(--border); margin: 14px 0; }

  .footer { text-align: center; margin-top: 40px; padding-top: 20px; border-top: 1px solid var(--border); color: var(--text-muted); font-size: 12px; }
  .footer strong { color: var(--text-dim); }

  @media (max-width: 600px) { .param-grid { grid-template-columns: 1fr 1fr; } .header h1 { font-size: 22px; } }
</style>
</head>
<body>
<div class="app">
  <div class="header">
    <div class="header-badge">🔬 Nefroloji Hesap Makinesi</div>
    <h1>Spot İdrar Analiz Algoritması</h1>
    <p class="author">Dr. Kağan Karamustafalıoğlu tarafından oluşturuldu.</p>
  </div>

  <!-- SPOT İDRAR -->
  <div class="param-group" id="grp-urine">
    <div class="param-group-header" onclick="toggleGroup('grp-urine')">
      <div class="param-group-title"><div class="param-group-icon icon-urine">🧪</div>Spot İdrar Parametreleri</div>
      <span class="chevron open" id="chev-grp-urine">▾</span>
    </div>
    <div class="param-group-body open" id="body-grp-urine">
      <div class="param-grid">
        <div class="input-wrap">
          <label>Sodyum (UNa) <span class="unit">mEq/L</span></label>
          <input type="number" id="u_na" placeholder="20–220" step="any">
        </div>
        <div class="input-wrap">
          <label>Potasyum (UK) <span class="unit">mEq/L</span></label>
          <input type="number" id="u_k" placeholder="10–60" step="any">
        </div>
        <div class="input-wrap">
          <label>Kalsiyum (UCa) <span class="unit">mg/dL</span></label>
          <input type="number" id="u_ca" placeholder="< 20" step="any">
        </div>
        <div class="input-wrap">
          <label>Kreatinin (UCr) <span class="unit">mg/dL</span></label>
          <input type="number" id="u_cr" placeholder="20–300" step="any">
        </div>
        <div class="input-wrap">
          <label>Albumin (UAlb) <span class="unit">mg/L</span></label>
          <input type="number" id="u_alb" placeholder="" step="any">
        </div>
        <div class="input-wrap">
          <label>Protein (UProt) <span class="unit">mg/dL</span></label>
          <input type="number" id="u_prot" placeholder="" step="any">
        </div>
        <div class="input-wrap">
          <label>Üre (UÜre) <span class="unit">mg/dL</span></label>
          <input type="number" id="u_urea" placeholder="" step="any">
        </div>
        <div class="input-wrap">
          <label>Glukoz (UGlukoz) <span class="unit">mg/dL</span></label>
          <input type="number" id="u_glukoz" placeholder="" step="any">
        </div>
        <div class="input-wrap">
          <label>Osmolalite (UOsm) <span class="unit">mOsm/kg</span></label>
          <input type="text" id="u_osm_display" disabled placeholder="Otomatik hesaplanır">
          <div class="osm-formula-hint">= 2×UNa + UÜre/6 + UGlukoz/18</div>
          <div class="osm-calc-indicator" id="u_osm_status"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- SERUM -->
  <div class="param-group" id="grp-serum">
    <div class="param-group-header" onclick="toggleGroup('grp-serum')">
      <div class="param-group-title"><div class="param-group-icon icon-serum">🩸</div>Serum Parametreleri</div>
      <span class="chevron open" id="chev-grp-serum">▾</span>
    </div>
    <div class="param-group-body open" id="body-grp-serum">
      <div class="param-grid">
        <div class="input-wrap">
          <label>Sodyum (SNa) <span class="unit">mEq/L</span></label>
          <input type="number" id="s_na" placeholder="136–145" step="any">
        </div>
        <div class="input-wrap">
          <label>Potasyum (SK) <span class="unit">mEq/L</span></label>
          <input type="number" id="s_k" placeholder="3.5–5.0" step="any">
        </div>
        <div class="input-wrap">
          <label>Kreatinin (SCr) <span class="unit">mg/dL</span></label>
          <input type="number" id="s_cr" placeholder="0.7–1.2" step="any">
        </div>
        <div class="input-wrap">
          <label>Üre (SÜre) <span class="unit">mg/dL</span></label>
          <input type="number" id="s_urea" placeholder="" step="any">
        </div>
        <div class="input-wrap">
          <label>Glukoz (SGlukoz) <span class="unit">mg/dL</span></label>
          <input type="number" id="s_glukoz" placeholder="70–100" step="any">
        </div>
        <div class="input-wrap">
          <label>Osmolalite (SOsm) <span class="unit">mOsm/kg</span></label>
          <input type="text" id="s_osm_display" disabled placeholder="Otomatik hesaplanır">
          <div class="osm-formula-hint">= 2×SNa + SÜre/6 + SGlukoz/18</div>
          <div class="osm-calc-indicator" id="s_osm_status"></div>
        </div>
      </div>
    </div>
  </div>

  <div class="actions">
    <button class="btn btn-primary" onclick="calculate()">Hesapla</button>
    <button class="btn btn-secondary" onclick="clearAll()">Temizle</button>
  </div>

  <div class="results-container" id="results"></div>

  <div class="footer">
    <strong>MEÜTF Nefroloji</strong> · Spot İdrar Analiz Algoritması<br>
    Klinik karar destek aracıdır — tanısal kesinlik için klinik bağlam gereklidir.
  </div>
</div>

<script>
function toggleGroup(id) {
  document.getElementById('body-' + id).classList.toggle('open');
  document.getElementById('chev-' + id).classList.toggle('open');
}

function val(id) {
  const v = document.getElementById(id).value;
  return v === '' ? null : parseFloat(v);
}

function clearAll() {
  document.querySelectorAll('input:not([disabled])').forEach(i => i.value = '');
  ['u_osm_display','s_osm_display'].forEach(id => document.getElementById(id).value = '');
  ['u_osm_status','s_osm_status'].forEach(id => document.getElementById(id).innerHTML = '');
  document.getElementById('results').innerHTML = '';
}

// ===== OTOMATİK OSMOLALİTE =====
function calcUOsm() {
  const na = val('u_na'), urea = val('u_urea'), glk = val('u_glukoz');
  const d = document.getElementById('u_osm_display'), s = document.getElementById('u_osm_status');
  if (na !== null && urea !== null && glk !== null) {
    d.value = ((2 * na) + (urea / 6) + (glk / 18)).toFixed(0) + ' mOsm/kg';
    s.innerHTML = '✓ Hesaplandı';
  } else {
    d.value = '';
    let m = [];
    if (na === null) m.push('UNa'); if (urea === null) m.push('UÜre'); if (glk === null) m.push('UGlukoz');
    s.innerHTML = m.length < 3 ? '⏳ Eksik: ' + m.join(', ') : '';
  }
}

function calcSOsm() {
  const na = val('s_na'), urea = val('s_urea'), glk = val('s_glukoz');
  const d = document.getElementById('s_osm_display'), s = document.getElementById('s_osm_status');
  if (na !== null && urea !== null && glk !== null) {
    d.value = ((2 * na) + (urea / 6) + (glk / 18)).toFixed(0) + ' mOsm/kg';
    s.innerHTML = '✓ Hesaplandı';
  } else {
    d.value = '';
    let m = [];
    if (na === null) m.push('SNa'); if (urea === null) m.push('SÜre'); if (glk === null) m.push('SGlukoz');
    s.innerHTML = m.length < 3 ? '⏳ Eksik: ' + m.join(', ') : '';
  }
}

['u_na','u_urea','u_glukoz'].forEach(id => document.getElementById(id).addEventListener('input', calcUOsm));
['s_na','s_urea','s_glukoz'].forEach(id => document.getElementById(id).addEventListener('input', calcSOsm));

function getUOsm() {
  const na = val('u_na'), urea = val('u_urea'), glk = val('u_glukoz');
  return (na !== null && urea !== null && glk !== null) ? (2*na) + (urea/6) + (glk/18) : null;
}
function getSOsm() {
  const na = val('s_na'), urea = val('s_urea'), glk = val('s_glukoz');
  return (na !== null && urea !== null && glk !== null) ? (2*na) + (urea/6) + (glk/18) : null;
}

// ===== ANA HESAPLAMA =====
function calculate() {
  const u_na=val('u_na'), u_k=val('u_k'), u_ca=val('u_ca'), u_cr=val('u_cr');
  const u_alb=val('u_alb'), u_prot=val('u_prot'), u_urea=val('u_urea');
  const u_osm=getUOsm(), s_na=val('s_na'), s_k=val('s_k'), s_cr=val('s_cr');
  const s_urea=val('s_urea'), s_osm=getSOsm();

  let C = [], S = [];

  // --- Spot değer yorumları ---
  if (u_na !== null) {
    let st, b, dh='';
    if (u_na>=20&&u_na<=220){st='Normal aralıkta';b='normal';}else if(u_na<20){st='Düşük';b='low';}else{st='Yüksek';b='high';}
    if(u_na<20) dh=buildDiff('Azalmış UNa Nedenleri',['Prerenal AKI','Dehidratasyon','Kalp yetmezliği','Siroz','Nefrotik sendrom']);
    else if(u_na>220) dh=buildDiff('Artmış UNa Nedenleri',['Diüretik kullanımı','Akut tübüler nekroz','Tuz alımı fazla','Adrenal yetmezlik','SIADH']);
    C.push(card('Spot İdrar Sodyum (UNa)',u_na.toFixed(1)+' mEq/L',st,b,'Referans: 20–220 mEq/L',null,dh));
  }
  if (u_k !== null) {
    let st,b,dh='';
    if(u_k>=10&&u_k<=60){st='Normal aralıkta';b='normal';}else if(u_k<10){st='Düşük';b='low';}else{st='Yüksek';b='high';}
    if(u_k<10) dh=buildDiff('Azalmış UK Nedenleri',['Böbrek yetmezliği','ACEi/ARB','Spironolakton','Addison hastalığı']);
    else if(u_k>60) dh=buildDiff('Artmış UK Nedenleri',['Hiperaldosteronizm','Diüretikler (loop, tiazid)','Kusma sonrası','Hipomagnezemi','RTA','Bartter, Gitelman']);
    C.push(card('Spot İdrar Potasyum (UK)',u_k.toFixed(1)+' mEq/L',st,b,'Referans: 10–60 mEq/L',null,dh));
  }
  if (u_ca !== null) {
    let st,b,dh='';
    if(u_ca<20){st='Normal';b='normal';}else{st='Yüksek';b='high';}
    if(u_ca>=20) dh=buildDiff('Hiperkalsiüri Nedenleri',['Hiperparatiroidi','Malignite','Sarkoidoz','Vitamin D fazlalığı','İmmobilizasyon','Loop diüretikleri','Renal taş hastalığı']);
    C.push(card('Spot İdrar Kalsiyum (UCa)',u_ca.toFixed(1)+' mg/dL',st,b,'Referans: < 20 mg/dL',null,dh));
  }
  if (u_cr !== null) {
    let st,b;
    if(u_cr>=20&&u_cr<=300){st='Normal aralıkta';b='normal';}else if(u_cr<20){st='Düşük — dilüe örnek?';b='low';}else{st='Yüksek — konsantre örnek';b='high';}
    C.push(card('Spot İdrar Kreatinin (UCr)',u_cr.toFixed(1)+' mg/dL',st,b,'Referans: 20–300 mg/dL'));
  }

  // Hesaplanan osmolaliteler
  if(u_osm!==null) C.push(card('İdrar Osmolalitesi (UOsm) — hesaplanan',u_osm.toFixed(0)+' mOsm/kg','Hesaplandı','info','Formülle hesaplanan tahmini değerdir','UOsm = 2×UNa + UÜre/6 + UGlukoz/18'));
  if(s_osm!==null) C.push(card('Serum Osmolalitesi (SOsm) — hesaplanan',s_osm.toFixed(0)+' mOsm/kg','Hesaplandı','info','Formülle hesaplanan tahmini değerdir','SOsm = 2×SNa + SÜre/6 + SGlukoz/18'));

  // --- Oranlar ---
  // ACR
  if(u_alb!==null&&u_cr!==null){
    const v=(u_alb*100)/u_cr;let st,b,d,dh='';
    if(v<30){st='Normal';b='normal';d='ACR < 30 mg/g → Normal albuminüri';}
    else if(v<=300){st='Mikroalbuminüri';b='low';d='ACR 30–300 mg/g → Mikroalbuminüri (A2)';}
    else{st='Makroalbuminüri';b='high';d='ACR > 300 mg/g → Makroalbuminüri (A3)';}
    if(v>=30) dh=buildDiff('Albuminüri Nedenleri',['Diyabetik nefropati','Hipertansiyon','Glomerülonefrit','Preeklampsi','Egzersiz','Ateş','Enfeksiyon']);
    C.push(card('Albumin/Kreatinin Oranı (ACR)',v.toFixed(1)+' mg/g',st,b,d,'ACR = UAlb × 100 / UCr',dh));
  } else if(u_alb!==null&&u_cr===null) S.push(sug('ACR Hesaplanabilir','İdrar kreatinini (UCr) girerseniz <strong>ACR</strong> hesaplanabilir → Diyabetik nefropati taraması.'));
  else if(u_alb===null&&u_cr!==null) S.push(sug('ACR Hesaplanabilir','İdrar albumini (UAlb) girerseniz <strong>ACR</strong> hesaplanabilir → Diyabetik nefropati taraması.'));

  // PCR
  if(u_prot!==null&&u_cr!==null){
    const v=(u_prot*1000)/u_cr;let st,b,d;
    if(v<150){st='Normal';b='normal';d='PCR < 150 mg/g → Normal';}
    else if(v<=500){st='Hafif proteinüri';b='low';d='PCR 150–500 mg/g → Hafif';}
    else if(v<=3500){st='Orta proteinüri';b='low';d='PCR 500–3500 mg/g → Orta';}
    else{st='Nefrotik düzey';b='high';d='PCR > 3500 mg/g → Nefrotik (≈ >3.5 g/gün)';}
    C.push(card('Protein/Kreatinin Oranı (PCR)',v.toFixed(0)+' mg/g',st,b,d,'PCR = UProt × 1000 / UCr'));
  } else if(u_prot!==null&&u_cr===null) S.push(sug('PCR Hesaplanabilir','İdrar kreatinini (UCr) girerseniz <strong>PCR</strong> hesaplanabilir → 24 saatlik protein tahmini.'));
  else if(u_prot===null&&u_cr!==null&&u_alb===null) S.push(sug('PCR veya ACR','İdrar proteini veya albumini girerseniz <strong>PCR</strong> veya <strong>ACR</strong> hesaplanabilir.'));

  // Ca/Cr
  if(u_ca!==null&&u_cr!==null){
    const v=u_ca/u_cr;let st,b,d,dh='';
    if(v<0.2){st='Normal';b='normal';d='Ca/Cr < 0.2 mg/mg → Normal (erişkin)';}
    else{st='Hiperkalsiüri';b='high';d='Ca/Cr ≥ 0.2 mg/mg → Hiperkalsiüri';}
    if(v>=0.2) dh=buildDiff('Hiperkalsiüri Nedenleri',['Hiperparatiroidi','Malignite','Sarkoidoz','Vitamin D fazlalığı','İmmobilizasyon','Loop diüretikleri','Renal taş hastalığı']);
    C.push(card('Kalsiyum/Kreatinin Oranı',v.toFixed(3)+' mg/mg',st,b,d,'Ca/Cr = UCa / UCr',dh));
  } else if(u_ca!==null&&u_cr===null) S.push(sug('Ca/Cr Hesaplanabilir','İdrar kreatinini (UCr) girerseniz <strong>Ca/Cr</strong> hesaplanabilir → Hiperkalsiüri.'));

  // Na/Cr
  if(u_na!==null&&u_cr!==null){
    const v=(u_na*100)/u_cr;let st,b;
    if(v>=40&&v<=220){st='Normal aralıkta';b='normal';}else if(v<40){st='Düşük';b='low';}else{st='Yüksek';b='high';}
    C.push(card('Sodyum/Kreatinin Oranı',v.toFixed(1)+' mEq/g',st,b,'Referans: ~40–220 mEq/g','Na/Cr = UNa × 100 / UCr'));
  }

  // K/Cr
  if(u_k!==null&&u_cr!==null){
    const v=(u_k*100)/u_cr;let st,b;
    if(v>=20&&v<=60){st='Normal aralıkta';b='normal';}else if(v<20){st='Düşük';b='low';}else{st='Yüksek';b='high';}
    C.push(card('Potasyum/Kreatinin Oranı',v.toFixed(1)+' mEq/g',st,b,'Referans: ~20–60 mEq/g','K/Cr = UK × 100 / UCr'));
  }

  // FENa
  if(u_na!==null&&s_cr!==null&&s_na!==null&&u_cr!==null){
    const v=((u_na*s_cr)/(s_na*u_cr))*100;let st,b,d;
    if(v<1){st='Prerenal';b='low';d='FENa < %1 → Prerenal (dehidratasyon, KY, hepatorenal)';}
    else if(v<=2){st='Gri alan';b='info';d='FENa %1–2 → Gri alan — klinik bağlam gerekli';}
    else{st='İntrinsik (ATN)';b='high';d='FENa > %2 → ATN veya intrinsik renal neden';}
    C.push(card('Fraksiyonel Sodyum Atılımı (FENa)','%'+v.toFixed(2),st,b,d,'FENa = (UNa × SCr) / (SNa × UCr) × 100'));
  } else {
    let m=[];if(u_na===null)m.push('İdrar Na');if(u_cr===null)m.push('İdrar Cr');if(s_na===null)m.push('Serum Na');if(s_cr===null)m.push('Serum Cr');
    if(m.length>0&&m.length<4) S.push(sug('FENa Hesaplanabilir','<strong>'+m.join(', ')+'</strong> girerseniz <strong>FENa</strong> hesaplanabilir → Prerenal vs. ATN.'));
  }

  // FEUrea
  if(u_urea!==null&&s_urea!==null&&s_cr!==null&&u_cr!==null){
    const v=((u_urea*s_cr)/(s_urea*u_cr))*100;let st,b,d;
    if(v<35){st='Prerenal';b='low';d='FEÜre < %35 → Prerenal (diüretik altında FENa yerine tercih edilir)';}
    else if(v<=50){st='Gri alan';b='info';d='FEÜre %35–50 → Gri alan';}
    else{st='İntrinsik (ATN)';b='high';d='FEÜre > %50 → ATN / intrinsik renal neden';}
    C.push(card('Fraksiyonel Üre Atılımı (FEÜre)','%'+v.toFixed(2),st,b,d,'FEÜre = (UÜre × SCr) / (SÜre × UCr) × 100'));
  } else {
    let m=[];if(u_urea===null)m.push('İdrar Üre');if(s_urea===null)m.push('Serum Üre');if(u_cr===null)m.push('İdrar Cr');if(s_cr===null)m.push('Serum Cr');
    if(m.length>0&&m.length<4) S.push(sug('FEÜre Hesaplanabilir','<strong>'+m.join(', ')+'</strong> girerseniz <strong>FEÜre</strong> hesaplanabilir → Diüretik altında prerenal vs. ATN.'));
  }

  // TTKG
  if(u_k!==null&&s_k!==null&&u_osm!==null&&s_osm!==null){
    if(u_osm>s_osm){
      const v=(u_k/s_k)/(u_osm/s_osm);let st,b,d;
      if(s_k<3.5){
        if(v<3){st='Ekstrarenal kayıp';b='low';d='Hipokalemi + TTKG < 3 → Ekstrarenal K kaybı (GİS, yetersiz alım)';}
        else{st='Renal kayıp';b='high';d='Hipokalemi + TTKG > 3 → Renal K kaybı (aldosteronizm, diüretik, RTA, Bartter/Gitelman)';}
      } else if(s_k>5.0){
        if(v<7){st='Yetersiz renal atılım';b='high';d='Hiperkalemi + TTKG < 7 → Aldosteron eksikliği/direnci (hipoaldo, tip 4 RTA, K-tutucu diüretik)';}
        else{st='Uygun renal yanıt';b='normal';d='Hiperkalemi + TTKG ≥ 7 → Böbrek uygun K atıyor → Ekstrarenal neden araştır';}
      } else{st='Normokalemide';b='info';d='Serum K normal — TTKG hipo/hiperkalemide daha anlamlıdır';}
      C.push(card('Transtübüler K Gradienti (TTKG)',v.toFixed(1),st,b,d,'TTKG = (UK / SK) / (UOsm / SOsm)'));
    } else {
      C.push(card('TTKG','—','Hesaplanamadı','grey','UOsm ('+u_osm.toFixed(0)+') ≤ SOsm ('+s_osm.toFixed(0)+') → TTKG geçerli değil'));
    }
  } else {
    let m=[];if(u_k===null)m.push('İdrar K');if(s_k===null)m.push('Serum K');
    if(u_osm===null)m.push('İdrar Osm (UNa+UÜre+UGlukoz)');if(s_osm===null)m.push('Serum Osm (SNa+SÜre+SGlukoz)');
    if(m.length>0&&m.length<4) S.push(sug('TTKG Hesaplanabilir','<strong>'+m.join(', ')+'</strong> girerseniz <strong>TTKG</strong> hesaplanabilir → Hipo/hiperkalemi ayırıcı tanı.'));
  }

  // Render
  const el=document.getElementById('results');
  if(!C.length&&!S.length){el.innerHTML='<div class="suggestion-card"><h4>⚠️ Parametre girilmedi</h4><p>Lütfen en az bir parametre girin.</p></div>';return;}
  let o='';
  if(C.length) o+='<div class="results-title">📊 Sonuçlar</div>'+C.join('');
  if(S.length) o+='<div class="results-title" style="margin-top:24px">💡 Öneriler</div>'+S.join('');
  el.innerHTML=o;
  el.scrollIntoView({behavior:'smooth',block:'start'});
}

function card(name,value,status,bType,detail,formula,extra){
  const bc=bType==='normal'?'badge-normal':bType==='high'?'badge-high':bType==='low'?'badge-low':bType==='info'?'badge-info':'badge-grey';
  const ic=bType==='normal'?'✓':bType==='high'?'↑':bType==='low'?'↓':bType==='info'?'ℹ':'—';
  let h='<div class="result-card"><div class="result-card-header"><span class="result-card-name">'+name+'</span><span class="result-card-value">'+value+'</span></div>';
  h+='<span class="result-badge '+bc+'">'+ic+' '+status+'</span>';
  if(detail) h+='<div class="result-detail">'+detail+'</div>';
  if(formula) h+='<div class="result-formula">'+formula+'</div>';
  if(extra) h+=extra;
  return h+'</div>';
}
function sug(t,txt){return '<div class="suggestion-card"><h4>💡 '+t+'</h4><p>'+txt+'</p></div>';}
function buildDiff(t,items){
  let h='<div class="diff-section"><div class="section-divider"></div><div class="diff-title">'+t+'</div><div class="diff-tags">';
  items.forEach(i=>{h+='<span class="diff-tag">'+i+'</span>';});
  return h+'</div></div>';
}

document.addEventListener('DOMContentLoaded',()=>{
  document.querySelectorAll('input:not([disabled])').forEach(inp=>{inp.addEventListener('keydown',e=>{if(e.key==='Enter')calculate();});});
});
</script>
